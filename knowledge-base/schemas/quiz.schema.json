{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ascendrite.com/schemas/quiz.schema.json",
  "title": "Quiz Assessment Schema",
  "description": "JSON schema for diagnostic quizzes in the Ascendrite platform.",
  "type": "object",
  "required": [
    "quiz_id",
    "questions"
  ],
  "properties": {
    "quiz_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-quiz$"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "question_id",
          "text",
          "options",
          "correct_answer",
          "explanation"
        ],
        "properties": {
          "question_id": {
            "type": "string",
            "pattern": "^q\\d+$"
          },
          "text": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string"
            }
          },
          "correct_answer": {
            "type": "string"
          },
          "explanation": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
