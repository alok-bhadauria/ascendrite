{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ascendrite.com/schemas/practice.schema.json",
  "title": "Practice Skeleton Schema",
  "description": "JSON schema for practice skeletons in the Ascendrite platform.",
  "type": "object",
  "required": [
    "topic_id",
    "asset_id",
    "title",
    "language",
    "code"
  ],
  "properties": {
    "topic_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "asset_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-prac\\d+$"
    },
    "title": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "code": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
