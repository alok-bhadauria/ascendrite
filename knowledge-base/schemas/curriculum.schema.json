{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ascendrite.com/schemas/curriculum.schema.json",
  "title": "Subject Syllabus Schema",
  "description": "JSON schema for subject syllabus layout files in the Ascendrite platform.",
  "type": "object",
  "required": [
    "subject_id",
    "name",
    "category",
    "modules"
  ],
  "properties": {
    "subject_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": ["ai", "core-cs", "software-engineering", "web-development", "aptitude"]
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "topics"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "topics": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "title",
                "subtopics"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9-]+$"
                },
                "title": {
                  "type": "string"
                },
                "subtopics": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
