{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ascendrite.com/schemas/topic.schema.json",
  "title": "Topic Notes Schema",
  "description": "JSON schema for topic notes and content files in the Ascendrite platform.",
  "type": "object",
  "required": [
    "topic_id",
    "title",
    "version",
    "topic_metadata",
    "learning_outcomes",
    "content_sections"
  ],
  "properties": {
    "topic_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "topic_metadata": {
      "type": "object",
      "required": [
        "difficulty",
        "estimated_hours",
        "importance"
      ],
      "properties": {
        "difficulty": {
          "type": "string",
          "enum": ["Beginner", "Medium", "Hard", "Advanced"]
        },
        "estimated_hours": {
          "type": "number",
          "minimum": 0
        },
        "importance": {
          "type": "string",
          "enum": ["Low", "Medium", "High"]
        }
      },
      "additionalProperties": false
    },
    "learning_outcomes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "content_sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "content"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "callouts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "type",
                "title",
                "content"
              ],
              "properties": {
                "type": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
