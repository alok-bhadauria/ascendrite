{
  "**comment**": "Refined and structured according to Draft 2020-12 without emojis.",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ascendrite.com/schemas/revision.schema.json",
  "title": "Revision Card Schema",
  "description": "JSON schema for revision cards in the Ascendrite platform.",
  "type": "object",
  "required": [
    "topic_id",
    "title",
    "version",
    "content"
  ],
  "properties": {
    "topic_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "content": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
