{
  "name": "Ascendrite Knowledge Base Physical Layout",
  "description": "Defines the physical directory structure and asset suffix patterns of the knowledge-base.",
  "root_dir": "knowledge-base",
  "templates": {
    "standard-subject": {
      "schema_version": "1.0.0",
      "metadata_files": {
        "syllabus": "syllabus.json",
        "subject_metadata": "subject-metadata.json",
        "subject_map": "subject-map.json",
        "knowledge_assets": "knowledge-assets.json",
        "book_metadata": "book-metadata.json"
      },
      "asset_directories": {
        "notes": {
          "dir": "notes",
          "file_pattern": "{topic_id}.json"
        },
        "revision": {
          "dir": "revision",
          "file_pattern": "{topic_id}.json"
        },
        "interview": {
          "dir": "interview",
          "file_pattern": "{topic_id}.json"
        },
        "diagrams": {
          "dir": "diagrams",
          "file_pattern": "{topic_id}-dia1.json"
        },
        "examples": {
          "dir": "examples",
          "file_pattern": "{topic_id}-ex1.json"
        },
        "practice": {
          "dir": "practice",
          "file_pattern": "{topic_id}-prac1.json"
        },
        "quiz": {
          "dir": "quiz",
          "file_pattern": "{topic_id}-quiz.json"
        }
      }
    }
  },
