# ==============================================================================
# ASCENDRITE Environment Configuration Contract (.env.example)
# ==============================================================================
# This file is tracked in Git. Use placeholders only. Do not commit actual secrets.
#
# NOTE: Driver connection URI/URLs are constructed dynamically at runtime from
# individual fields. Credential components are automatically percent-encoded.
# ------------------------------------------------------------------------------

# ==============================================================================
# 1. Application Configuration
# ==============================================================================
APP_NAME=Ascendrite
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# ==============================================================================
# 2. Vector Backend
# ==============================================================================
VECTOR_BACKEND=pgvector

# ==============================================================================
# 3. PostgreSQL Database Configuration
# ==============================================================================
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=ascendrite
POSTGRES_ADMIN_USER=ascendrite_admin
POSTGRES_ADMIN_PASSWORD=your_postgres_admin_password_here
POSTGRES_APP_USER=ascendrite_app
POSTGRES_APP_PASSWORD=your_postgres_app_password_here

# ==============================================================================
# 4. MongoDB Configuration
# ==============================================================================
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_DATABASE=ascendrite
MONGODB_AUTH_SOURCE=admin
MONGODB_ADMIN_USER=ascendrite_admin
MONGODB_ADMIN_PASSWORD=your_mongodb_admin_password_here
MONGODB_APP_USER=ascendrite_app
MONGODB_APP_PASSWORD=your_mongodb_app_password_here

# ==============================================================================
# 5. Redis / Memurai Configuration
# ==============================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_ADMIN_USER=ascendrite_admin
REDIS_ADMIN_PASSWORD=your_redis_admin_password_here
REDIS_APP_USER=ascendrite_app
REDIS_APP_PASSWORD=your_redis_app_password_here

# ==============================================================================
# 6. RustFS (S3) Object Storage Configuration
# ==============================================================================
S3_ENDPOINT=http://127.0.0.1:9000
S3_CONSOLE_ENDPOINT=http://127.0.0.1:9001
S3_REGION=ap-south-1
S3_ADMIN_USER=ascendrite_admin
S3_ADMIN_PASSWORD=your_s3_admin_password_here
S3_APP_PARENT_USER=ascendrite_app
S3_RUNTIME_ACCESS_KEY=ascendrite_runtime
S3_RUNTIME_SECRET_KEY=your_s3_runtime_secret_key_here

# ==============================================================================
# 7. Authentication Configuration
# ==============================================================================
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================================================
# 8. AI Providers Configuration
# ==============================================================================
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ==============================================================================
# 9. Feature Flags Configuration
# ==============================================================================
ENABLE_AI=true
ENABLE_SIGNUPS=true
ENABLE_GOOGLE_LOGIN=true
