# Ascendrite Pre-Phase 0 Environment Configuration Contract
# This file is tracked in Git. Use placeholders only. Do not commit actual secrets.

# PostgreSQL Vector Database
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=ascendrite_vector
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# MongoDB Document Database
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_DATABASE=ascendrite
MONGODB_USER=admin
MONGODB_PASSWORD=your_mongodb_password_here

# Memurai / Redis Cache
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=your_redis_password_here

# RustFS S3 Object Storage API
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=ap-south-1
S3_ACCESS_KEY=your_s3_access_key_here
S3_SECRET_KEY=your_s3_secret_key_here

# Vector DB Backend Selection (pgvector adapts to this repository adapter interface)
VECTOR_BACKEND=pgvector

# Core Application established config URLs (derived from individual parameters above)
MONGODB_URI=mongodb://admin-ascendrite:your_mongodb_password_here@127.0.0.1:27017/?authSource=admin
MONGODB_DB_NAME=ascendrite
REDIS_URL=redis://127.0.0.1:6379/0
POSTGRES_URL=postgresql://postgres:your_postgres_password_here@127.0.0.1:5432/ascendrite_vector
