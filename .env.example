# ==============================================================================
# ASCENDRITE Pre-Phase 0 / V1 Environment Configuration Contract
# ==============================================================================
# This file is tracked in Git. Use placeholders only. Do not commit actual secrets.
#
# NOTE: Driver connection URI/URLs are constructed dynamically at runtime from
# individual fields. Credential components are automatically percent-encoded.
# ------------------------------------------------------------------------------

# Vector DB Backend Adapter Selection
VECTOR_BACKEND=pgvector

# ==============================================================================
# 1. PostgreSQL Database Configuration
# ==============================================================================
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=ascendrite

# Note: Superuser identity 'postgres' is excluded from regular config for security.

# Administrative / Migration Identity (Schema updates, indexes, tables ownership)
POSTGRES_ADMIN_USER=ascendrite_admin
POSTGRES_ADMIN_PASSWORD=your_postgres_admin_password_here

# Application Runtime Identity (Regular select, insert, update, delete operations)
POSTGRES_APP_USER=ascendrite_app
POSTGRES_APP_PASSWORD=your_postgres_app_password_here

# ==============================================================================
# 2. MongoDB Configuration
# ==============================================================================
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_DATABASE=ascendrite
MONGODB_AUTH_SOURCE=admin

# Note: Server root user 'ascendrite_mongo_root' is excluded from regular config.

# Administrative / Migration Identity (Collection setup, indexing, schema validations)
MONGODB_ADMIN_USER=ascendrite_admin
MONGODB_ADMIN_PASSWORD=your_mongodb_admin_password_here

# Application Runtime Identity (Standard read/write collection access)
MONGODB_APP_USER=ascendrite_app
MONGODB_APP_PASSWORD=your_mongodb_app_password_here

# ==============================================================================
# 3. Memurai / Redis Cache Configuration
# ==============================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0

# Cache Maintenance Identity (Flushdb, configuration updates, monitoring)
REDIS_ADMIN_USER=ascendrite_cache_admin
REDIS_ADMIN_PASSWORD=your_redis_admin_password_here

# Cache Application Runtime Identity (Get, set, delete cache operations)
REDIS_APP_USER=ascendrite_cache_app
REDIS_APP_PASSWORD=your_redis_app_password_here

# ==============================================================================
# 4. RustFS S3-Compatible Object Storage Configuration
# ==============================================================================
S3_ENDPOINT=http://127.0.0.1:9000
S3_CONSOLE_ENDPOINT=http://127.0.0.1:9001
S3_REGION=ap-south-1

# Note: Storage system root 'ascendrite_storage_root' is excluded from regular config.

# Administrative Identity (Bucket management, policy setups, migrations)
S3_ADMIN_USER=ascendrite_storage_admin
S3_ADMIN_PASSWORD=your_s3_admin_password_here

# Application Runtime Access Keys (S3 authentications)
S3_APP_PARENT_USER=ascendrite_storage_app
S3_RUNTIME_ACCESS_KEY=ascendrite_runtime
S3_RUNTIME_SECRET_KEY=your_s3_runtime_secret_key_here
